{
  "name": "@smart-link/theme",
  "version": "1.0.0",
  "description": "SmartLink theme system",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles/variables.scss": "./dist/styles/variables.scss"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c ../../internal/build/rollup.config.js && node -e \"import('fs').then(fs=>fs.cpSync('src/styles', 'dist/styles', {recursive:true}))\""
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "loylin",
  "license": "MIT"
}
