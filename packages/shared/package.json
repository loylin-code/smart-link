{
  "name": "@smart-link/shared",
  "version": "1.0.0",
  "description": "SmartLink shared utilities and types",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c ../../internal/build/rollup.config.js",
    "dev": "rollup -c ../../internal/build/rollup.config.js -w"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/loylin-code/smart-link"
  },
  "author": "loylin",
  "license": "MIT"
}
