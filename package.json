{
  "name": "smart-link-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "SmartLink - AI-powered page orchestration platform",
  "type": "module",
  "scripts": {
    "dev": "pnpm -F @smart-link/app dev",
    "play": "pnpm -F @smart-link/play dev",
    "docs": "pnpm -F @smart-link/docs dev",
    "build": "turbo run build",
    "build:lib": "turbo run build --filter='./packages/*'",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx --fix",
    "format": "prettier --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build:lib && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.11.25",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.22.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "rollup": "^4.12.0",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "rollup-plugin-vue": "^6.0.0",
    "sass": "^1.71.1",
    "tslib": "^2.8.1",
    "turbo": "^2.0.0",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vitepress": "^1.0.0",
    "vue": "^3.4.21",
    "vue-tsc": "^2.0.6"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
